theme = light:Apple System Colors Light,dark:vesper

font-family = "IosevkaTerm NFM"
font-size = 17

shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

confirm-close-surface = false
clipboard-paste-protection = false
copy-on-select = true

scrollback-limit = 4294967295
keybind = shift+enter=text:\n

# Split below current pane, inheriting its CWD (split-inherit-working-directory).
# Not global; per-tab CWD is preserved since each tab is its own surface.
# Splits open 50/50; chain a resize to shrink the new bottom pane (~200px).
keybind = cmd+grave_accent=new_split:down
keybind = chain=resize_split:down,500

macos-option-as-alt = true

unfocused-split-opacity = 0.7
unfocused-split-fill = #333333

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true
